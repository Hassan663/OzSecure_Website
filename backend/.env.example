# ===== Server =====
PORT=5000
# Comma-separated list of allowed origins (your Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# ===== Email (Resend) =====
# Lead emails are sent via Resend (https://resend.com). The API key comes ONLY
# from this env var — never commit a real key. If RESEND_API_KEY is unset, email
# is disabled (leads still save; a warning is logged), so dev works without it.
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# ⚠  VERIFY YOUR DOMAIN in Resend before going live. Until ozsecuresecurity.com.au
#    is verified, MAIL_FROM MUST be "onboarding@resend.dev" — and that onboarding
#    sender can ONLY deliver to your own Resend account email. After verifying the
#    domain, set MAIL_FROM to a @ozsecuresecurity.com.au address to email anyone.
#
# MAIL_FROM="OzSecure Services <onboarding@resend.dev>"
# MAIL_TO=info@ozsecuresecurity.com.au

# ===== Storage (OPTIONAL) =====
# Leave MONGODB_URI empty/unset to use the local JSON-file store (backend/data/queries.json).
# Set it to switch to MongoDB automatically — no code changes needed.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/ozsecure?retryWrites=true&w=majority

# ===== Admin panel =====
# Single admin login. If unset, dev defaults are used (password "admin123" + an
# insecure JWT secret) with a loud startup warning — SET THESE IN PRODUCTION.
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-to-a-long-random-string
