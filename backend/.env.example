# ===== Server =====
PORT=5000
# Comma-separated list of allowed origins (your Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# ===== SMTP (email delivery for quote requests) =====
# Leave SMTP_HOST empty to run in DEV mode — requests are logged to the console
# instead of being emailed, so you can test the form without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where quote/contact submissions are sent and who they appear to come from
MAIL_TO=info@ozsecuresecurity.com.au
MAIL_FROM="OzSecure Website <no-reply@ozsecuresecurity.com.au>"

# ===== Storage (OPTIONAL) =====
# Leave MONGODB_URI empty/unset to use the local JSON-file store (backend/data/queries.json).
# Set it to switch to MongoDB automatically — no code changes needed.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/ozsecure?retryWrites=true&w=majority

# ===== Admin panel =====
# Single admin login. If unset, dev defaults are used (password "admin123" + an
# insecure JWT secret) with a loud startup warning — SET THESE IN PRODUCTION.
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-to-a-long-random-string
