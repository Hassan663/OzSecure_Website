# OZsecure Services — repository ignore rules

# Dependencies
node_modules/

# Next.js build output
.next/
out/
build/
dist/
*.tsbuildinfo

# Environment files — NEVER commit real secrets.
# The committed *.example files are the templates to copy.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.local.example

# Local JSON store (created at runtime when MONGODB_URI is not set)
backend/data/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Deploy / tooling
.vercel

# OS / editor
.DS_Store
Thumbs.db
